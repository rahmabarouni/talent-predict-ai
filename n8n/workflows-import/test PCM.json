                      "parameters":  {
                                         "jsCode":  "// Get data from webhook body\nconst body = $input.first().json.body || $input.first().json;\n\nconst userName = body[\u0027Votre nom complet\u0027] || body.user_name || \"Anonymous\";\n\n// Extract question responses (Q1-Q18)\nconst q1  = Number(body.q1  || body[\u0027Q1\u0027]  || 0);\nconst q2  = Number(body.q2  || body[\u0027Q2\u0027]  || 0);\nconst q3  = Number(body.q3  || body[\u0027Q3\u0027]  || 0);\nconst q4  = Number(body.q4  || body[\u0027Q4\u0027]  || 0);\nconst q5  = Number(body.q5  || body[\u0027Q5\u0027]  || 0);\nconst q6  = Number(body.q6  || body[\u0027Q6\u0027]  || 0);\nconst q7  = Number(body.q7  || body[\u0027Q7\u0027]  || 0);\nconst q8  = Number(body.q8  || body[\u0027Q8\u0027]  || 0);\nconst q9  = Number(body.q9  || body[\u0027Q9\u0027]  || 0);\nconst q10 = Number(body.q10 || body[\u0027Q10\u0027] || 0);\nconst q11 = Number(body.q11 || body[\u0027Q11\u0027] || 0);\nconst q12 = Number(body.q12 || body[\u0027Q12\u0027] || 0);\nconst q13 = Number(body.q13 || body[\u0027Q13\u0027] || 0);\nconst q14 = Number(body.q14 || body[\u0027Q14\u0027] || 0);\nconst q15 = Number(body.q15 || body[\u0027Q15\u0027] || 0);\nconst q16 = Number(body.q16 || body[\u0027Q16\u0027] || 0);\nconst q17 = Number(body.q17 || body[\u0027Q17\u0027] || 0);\nconst q18 = Number(body.q18 || body[\u0027Q18\u0027] || 0);\n\n// Calculate scores\nconst scores = {\n  communication: Math.round((q1 + q2 + q3) / 3 * 10) / 10,\n  discipline:    Math.round((q4 + q5 + q6) / 3 * 10) / 10,\n  curiosity:     Math.round((q7 + q8 + q9) / 3 * 10) / 10,\n  collaboration: Math.round((q10 + q11 + q12) / 3 * 10) / 10,\n  ownership:     Math.round((q13 + q14 + q15) / 3 * 10) / 10,\n  leadership:    Math.round((q16 + q17 + q18) / 3 * 10) / 10\n};\n\nconst overall = Math.round(\n  Object.values(scores).reduce((a, b) =\u003e a + b, 0) / 6 * 10\n) / 10;\n\nconst skillsArray = Object.entries(scores).map(([skill, score]) =\u003e ({ skill, score }));\nskillsArray.sort((a, b) =\u003e b.score - a.score);\n\nconst result = {\n  user_name: userName,\n  timestamp: new Date().toISOString(),\n  soft_skills: {\n    communication: { score: scores.communication, evidence: \"Self-assessment via PCM test\" },\n    discipline:    { score: scores.discipline,    evidence: \"Self-assessment via PCM test\" },\n    curiosity:     { score: scores.curiosity,     evidence: \"Self-assessment via PCM test\" },\n    collaboration: { score: scores.collaboration, evidence: \"Self-assessment via PCM test\" },\n    ownership:     { score: scores.ownership,     evidence: \"Self-assessment via PCM test\" },\n    leadership:    { score: scores.leadership,    evidence: \"Self-assessment via PCM test\" }\n  },\n  overall_score: overall,\n  top_strength: skillsArray[0].skill,\n  main_weakness: skillsArray[skillsArray.length - 1].skill,\n  source: \"PCM\",\n  raw_responses: { q1,q2,q3,q4,q5,q6,q7,q8,q9,q10,q11,q12,q13,q14,q15,q16,q17,q18 }\n};\n\nreturn [{ json: result }];"
                                     },
